# =============================================================================
# HSA AI Agent 环境变量模板
# 复制此文件为 .env 并填入实际值:  cp .env.example .env
# =============================================================================

# ── LLM 供应商 API Keys (必填, 至少配置一个) ──────────────────────────────
# 供应商 Key 名称在 app/llm_providers.json 中定义, 此处列出常见的:
OPENAI_API_KEY=
DASHSCOPE_API_KEY=
ARK_API_KEY=
DEEPSEEK_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=
SILICONFLOW_API_KEY=

# ── 数据库连接 ──────────────────────────────────────────────────────────────
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# ── Neo4j 图数据库 (可选, 不配置则回退到内存图谱) ─────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# ── 可观测性 (可选) ────────────────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://us.cloud.langfuse.com

# ── Web 服务器 ───────────────────────────────────────────────────────────────
UVICORN_HOST=127.0.0.1
UVICORN_PORT=18882
MONITOR_HOST=127.0.0.1

# ── CORS 跨域配置 ───────────────────────────────────────────────────────────
# 生产环境必须设置为实际前端域名, 逗号分隔
# 例: CORS_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://127.0.0.1:3000
CORS_ALLOW_CREDENTIALS=true

# ── 专家评审桥接 (可选) ────────────────────────────────────────────────────
EXPERT_CALLBACK_TOKEN=

# ── HuggingFace 镜像 (国内加速) ─────────────────────────────────────────────
HF_ENDPOINT=https://hf-mirror.com
HF_HOME=

# ── 审计缓存控制 ────────────────────────────────────────────────────────────
DISABLE_AUDIT_CACHE=false

# ── 健康检查间隔 (秒) ───────────────────────────────────────────────────────
HEALTH_CHECK_INTERVAL_SECONDS=300
